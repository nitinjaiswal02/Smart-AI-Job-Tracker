# Copy this file to .env and fill in real values.
# .env itself is gitignored — it should never be committed, since it will
# eventually hold real secrets (database passwords, API keys).

PORT=5001
NODE_ENV=development
# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/smart-job-tracker
# MongoDB Atlas (cloud, free tier):
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/smart-job-tracker?retryWrites=true&w=majority

// JWT settings for authentication
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173

// GROQ API key (used for AI features)
GROQ_API_KEY=your_groq_api_key_here

// Gmail SMTP settings for sending emails
GMAIL_USER=your_gmail_username@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

// razorpay used nitinproject49@gmail.com 
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret